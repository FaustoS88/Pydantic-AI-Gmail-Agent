# LLM — OpenRouter (recommended)
MY_OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM — fallback model if no OpenRouter key (uses OpenAI directly)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-5.4-mini

# Model override (default: google/gemini-3.5-flash via OpenRouter)
# GMAIL_AGENT_MODEL=google/gemini-2.0-flash-001

# Operation mode: "draft" (default, safe) or "auto" (sends directly)
OPERATION_MODE=draft

# Max starred emails to process per run
# MAX_STARRED_EMAILS=10

# Thinking effort: low | medium | high
# THINKING_EFFORT=high